---
import BaseLayout from '@layouts/BaseLayout.astro';
import Alert from '@components/ui/Alert.astro';
import { actions } from 'astro:actions';
import assert from 'node:assert';
import { AuthorizationError } from '@services/authorization-service.ts';
import type { TeamDto } from '@services/teams-service.ts';
import { createTeamsService } from '@lib/composition.ts';

const { user } = Astro.locals;
assert(user, 'User must be logged in.');

const { teamId } = Astro.params as { teamId: string };

let team: TeamDto | null = null;
let notAuthorized = false;
let notTeamLead = false;

try {
  const teamsService = createTeamsService(Astro.locals);
  team = await teamsService.getTeam(teamId);

  const teamLeads = team.members.filter((m) => m.role === 'team-lead');
  const isTeamLead = teamLeads.some((m) => m.userId === user.id);

  if (!isTeamLead) {
    notTeamLead = true;
  }
} catch (error) {
  if (error instanceof AuthorizationError) {
    notAuthorized = true;
  } else {
    return new Response('Not Found', { status: 404 });
  }
}

const result = Astro.getActionResult(actions.updateTeam);
if (result?.data?.success) {
  return Astro.redirect(`/teams/${teamId}`);
}

const breadcrumbs = team
  ? [
      { label: 'Home', href: '/' },
      { label: team.name, href: `/teams/${teamId}` },
      { label: 'Edit' },
    ]
  : undefined;
---

<BaseLayout title="Edit Team" breadcrumbs={breadcrumbs}>
  <div class="flex-1 py-8">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl mx-auto">
        {
          notAuthorized || notTeamLead ? (
            <div class="card bg-base-100 shadow-xl">
              <div class="card-body">
                <h1 class="card-title text-2xl">Access Denied</h1>
                <Alert type="warning">
                  You do not have permission to edit this team. Only team leads
                  can edit team details.
                </Alert>
                <div class="card-actions justify-end">
                  <a href={`/teams/${teamId}`} class="btn btn-primary">
                    Back to Team Details
                  </a>
                </div>
              </div>
            </div>
          ) : (
            team && (
              <div class="card bg-base-100 shadow-xl">
                <div class="card-body">
                  <h1 class="card-title text-2xl mb-4">Edit Team</h1>

                  {result?.error && (
                    <Alert
                      type="error"
                      class="mb-4"
                      messageClass="error-message"
                    >
                      {result.error.message}
                    </Alert>
                  )}

                  <form
                    method="POST"
                    action={actions.updateTeam}
                    class="space-y-4"
                  >
                    <input type="hidden" name="teamId" value={team.id} />

                    <div class="form-control w-full">
                      <label class="label" for="name">
                        <span class="label-text font-medium">Team Name</span>
                      </label>
                      <input
                        type="text"
                        id="name"
                        name="name"
                        value={team.name}
                        required
                        minlength="3"
                        maxlength="100"
                        class="input input-bordered w-full"
                        placeholder="Enter team name"
                      />
                      <label class="label">
                        <span class="label-text-alt">
                          Minimum 3 characters, maximum 100
                        </span>
                      </label>
                    </div>

                    <div class="form-control w-full">
                      <label class="label" for="description">
                        <span class="label-text font-medium">Description</span>
                      </label>
                      <textarea
                        id="description"
                        name="description"
                        class="textarea textarea-bordered w-full h-24"
                        placeholder="Enter team description (optional)"
                      >
                        {team.description ?? ''}
                      </textarea>
                      <label class="label">
                        <span class="label-text-alt">Optional</span>
                      </label>
                    </div>

                    <div class="card-actions justify-end gap-2 pt-4">
                      <a href={`/teams/${teamId}`} class="btn btn-ghost">
                        Cancel
                      </a>
                      <button type="submit" class="btn btn-primary">
                        Save Changes
                      </button>
                    </div>
                  </form>
                </div>
              </div>
            )
          )
        }
      </div>
    </div>
  </div>
</BaseLayout>
