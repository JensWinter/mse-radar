---
import BaseLayout from '@layouts/BaseLayout.astro';
import assert from 'node:assert';

const { user } = Astro.locals;
assert(user, 'User must be logged in.');
---

<BaseLayout title="Account">
  <div class="flex-1 py-8">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto space-y-6">
        <h1 class="text-3xl font-bold">Account Overview</h1>

        <div class="card bg-base-100 shadow-xl">
          <div class="card-body">
            <h2 class="card-title text-xl mb-4">Account Settings</h2>
            <div
              class="flex flex-col items-center justify-center py-8 text-center"
            >
              <span class="iconify lucide--settings h-12 w-12 opacity-50 mb-4"
              ></span>
              <p class="text-sm text-base-content/70 mb-4">
                Additional settings will be available here soon
              </p>
              <div class="flex gap-2">
                <button class="btn btn-sm opacity-50" disabled
                  >Change Password</button
                >
                <button class="btn btn-sm opacity-50" disabled
                  >Account Preferences</button
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
