---
import SummaryChart from '@components/survey-run/SummaryChart.astro';
import type { SurveyRun } from '@models/aggregates/survey-run.ts';
import { buildSurveyRunSummary } from './summary.ts';

interface Props {
  surveyRun: SurveyRun;
}

const { surveyRun } = Astro.props;
const summary = buildSurveyRunSummary(surveyRun);
---

<div
  class="flex flex-col md:flex-row justify-evenly items-center gap-6"
  data-testid="overall-summary"
>
  <div class="flex items-center">
    <div class="stats">
      <div class="stat">
        <div class="stat-title">Overall Score</div>
        <div class="stat-value" data-testid="overall-score">
          {surveyRun.calcAverageScore().toFixed(1)}
          <span class="text-sm font-normal text-base-content/60"> / 5 </span>
        </div>
        <div class="stat-desc" data-testid="total-responses">
          {surveyRun.responses.length}
          {surveyRun.responses.length === 1 ? 'Response' : 'Responses'}
        </div>
      </div>
    </div>
  </div>

  <div class="w-2/3 md:w-1/2">
    <SummaryChart summary={summary} />
  </div>
</div>
