---
import type { QuestionAnswer } from './types.ts';

interface Props {
  surveyRunId: string;
  questionIndex: number;
  question: QuestionAnswer;
  totalQuestions: number;
}

const { surveyRunId, questionIndex, question, totalQuestions } = Astro.props;
---

<div
  class="card bg-base-200 border border-base-300 relative"
  data-testid="question-card"
  x-data={`surveyAnswer('${surveyRunId}', ${questionIndex}, ${question.answerValue}, ${JSON.stringify(question.comment ?? '')}, ${totalQuestions})`}
>
  <div class="card-body p-4">
    <div class="absolute top-2 right-2 flex items-center gap-2">
      <span x-show="saving" class="loading loading-spinner loading-xs"></span>
    </div>
    <div class="flex flex-row items-center gap-2">
      <h2 class="card-title">{question.capabilityName}</h2>
      <button
        type="button"
        class="btn btn-ghost btn-xs btn-circle"
        aria-label={`Learn more about ${question.capabilityName}`}
        data-testid="capability-info-trigger"
        onclick={`document.getElementById('capability-info-modal-${questionIndex}').showModal()`}
      >
        <span class="iconify lucide--info" aria-hidden="true"></span>
      </button>
      <dialog id={`capability-info-modal-${questionIndex}`} class="modal">
        <div class="modal-box space-y-4">
          <h3 class="text-lg font-bold">{question.capabilityName}</h3>
          <p class="leading-6" data-testid="capability-description">
            {question.capabilityDescription}
          </p>
          <a
            href={question.doraReference}
            target="_blank"
            rel="noopener noreferrer"
            data-testid="capability-dora-link"
            class="link link-primary text-sm">Learn more on dora.dev</a
          >
          <div class="modal-action">
            <form method="dialog">
              <button class="btn">Close</button>
            </form>
          </div>
        </div>
      </dialog>
    </div>
    <p>{question.questionText}</p>

    <div class="space-y-2 mt-4">
      <div class="flex gap-1">
        {
          [1, 2, 3, 4, 5, 6, 7].map((num) => (
            <button
              type="button"
              data-testid={`answer-button-${num}`}
              @click={`saveAnswer(${num})`}
              x-bind:disabled="saving"
              x-bind:aria-pressed={`value === ${num} ? 'true' : 'false'`}
              x-bind:class={`value === ${num} ? 'btn-primary' : 'btn-ghost btn-soft'`}
              class="btn btn-sm flex-1"
            >
              {num}
            </button>
          ))
        }
      </div>
      <div
        class="relative flex items-center justify-between text-base-content/60"
      >
        <span>Strongly Disagree</span>
        <span class="absolute left-1/2 -translate-x-1/2">Neutral</span>
        <span>Strongly Agree</span>
      </div>
    </div>

    <div class="mt-4">
      <button
        type="button"
        @click="showComment()"
        x-show="!isCommentVisible"
        class="btn btn-ghost btn-xs px-0"
      >
        Add comment
      </button>

      <div x-show="isCommentVisible" class="form-control w-full">
        <label class="label" for={`comment-${question.questionId}`}
          >Your Comment</label
        >
        <textarea
          id={`comment-${question.questionId}`}
          x-model="comment"
          @input="scheduleCommentSave()"
          @blur="flushCommentSave()"
          placeholder="Optional comment"
          class="textarea textarea-bordered textarea-sm w-full text-xs mt-3"
          rows="2"></textarea>
        <div class="mt-2">
          <span
            x-show="showCommentSaved"
            x-transition
            class="text-xs text-success"
          >
            Saved
          </span>
        </div>
      </div>
    </div>
  </div>
</div>
