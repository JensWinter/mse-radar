{
  "tasks": {
    "run:astro:dev": "cd astro && npm run dev",
    "run:astro:preview": "cd astro && npx astro build && npx astro preview --no-update-check --no-open",
    "test:astro:unit": "cd astro && npm run test",
    "test:astro:e2e": "cd astro && npm run test:e2e",
    "test:unit": "deno test deno_scripts/ --permit-no-files",
    "test:acceptance": "deno run --allow-all --env-file=.env.acceptance acceptance/runAllSuites.ts",
    "db:migrate": "deno run --allow-env --allow-read --allow-net --env-file=.env.local deno_scripts/db/migrate.ts",
    "db:migrate-better-auth": "deno run --allow-env --allow-read --allow-net --env-file=.env.local deno_scripts/db_better-auth/migrate.ts",
    "db:seed": "deno run --allow-env --allow-read --allow-net --env-file=.env.local deno_scripts/db/seed_dora_capabilities.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/expect": "jsr:@std/expect@1",
    "@std/path": "jsr:@std/path",
    "@std/testing": "jsr:@std/testing@^1.0.16",
    "playwright": "npm:playwright@^1.57.0",
    "pg": "npm:pg@^8.16.0"
  },
  "lint": {
    "include": ["deno_scripts/", "acceptance/"],
    "exclude": []
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve",
    "include": ["deno_scripts/", "acceptance/"],
    "exclude": []
  },
  "nodeModulesDir": "auto"
}
